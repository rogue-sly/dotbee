{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gitlab.com/rogue87/dotsy/-/raw/main/schema/dotsy.json",
  "title": "Dotsy Configuration Schema",
  "description": "Configuration schema for Dotsy dotfiles manager",
  "type": "object",
  "properties": {
    "settings": {
      "type": "object",
      "description": "General settings for Dotsy",
      "properties": {
        "on_conflict": {
          "type": "string",
          "description": "How to handle conflicts. Options: 'overwrite', 'adopt', 'skip', 'abort', 'ask'. Default: 'ask' (interactive).",
          "enum": [
            "overwrite",
            "adopt",
            "skip",
            "abort",
            "ask"
          ],
          "default": "ask",
          "x-taplo": {
            "docs": {
              "enumValues": [
                "Overwrite the existing file with the symlink",
                "Adopt the existing file into your dotfiles (moves it to the source path)",
                "Skip symlinking this file",
                "Abort the operation",
                "Ask the user what to do (default)"
              ]
            }
          }
        },
        "icon_style": {
          "type": "string",
          "description": "The style of icons to use in the CLI output",
          "enum": [
            "text",
            "emoji",
            "nerdfont"
          ],
          "default": "text",
          "x-taplo": {
            "docs": {
              "enumValues": [
                "Plain text (e.g., [DONE], [ERROR])",
                "Emoji icons",
                "Nerd Font icons"
              ]
            }
          }
        },
        "auto_detect_profile": {
          "type": "boolean",
          "description": "Automatically select a profile based on the system's hostname when no profile is specified",
          "default": false
        }
      },
      "additionalProperties": false
    },

    "global": {
      "type": "object",
      "description": "Global configurations applied regardless of profile",
      "properties": {
        "links": {
          "type": "object",
          "description": "Symlinks to create: { 'destination': 'source' }",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "profiles": {
      "type": "object",
      "description": "Named profiles containing specific configurations",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "links": {
            "type": "object",
            "description": "Symlinks to create for this profile: { 'destination': 'source' }",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "required": [
          "links"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "settings"
  ]
}